OPENAI_API_KEY=sk-...
# Personal API key (phx_...) — PostHog Settings → Personal API keys — for REST queries
POSTHOG_PERSONAL_API_KEY=phx_...
# Project API key (phc_...) — PostHog Project Settings → Project API key — for event capture (seed)
POSTHOG_PROJECT_API_KEY=phc_...
POSTHOG_PROJECT_ID=12345
GITHUB_TOKEN=ghp_...
GITHUB_OWNER=your-org
GITHUB_REPO=nutribot
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
VERCEL_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/...

# HTTP server (webhook + health endpoint)
PORT=3000
# HMAC secret for PostHog webhook signature verification (optional but recommended)
WEBHOOK_SECRET=your-webhook-secret-here

# AI models — o3 for code generation, gpt-4o for vision (must support image inputs)
OPENAI_CODEGEN_MODEL=o3
OPENAI_VISION_MODEL=gpt-4o

# NutriBot production URL — enables before/after screenshots on each deploy
NUTRIBOT_URL=https://your-nutribot.vercel.app

# Optional: override drop-off threshold (default 30%)
DROP_OFF_THRESHOLD=0.3
# Optional: path to competitor PNG screenshots (default: ../competitor-screens/calorie-tracking)
COMPETITOR_SCREENSHOTS_DIR=
